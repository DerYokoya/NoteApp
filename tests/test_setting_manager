    """Create main window for testing"""
    window = MainWindow()
    qtbot.addWidget(window)
    return window

def test_main_window_initialization(main_window):
    """Test main window initializes correctly"""
    assert main_window.windowTitle() is not None
    assert main_window.tab_widget.count() == 1  # One untitled tab
    assert len(main_window.tabs) == 1

def test_new_tab(main_window):
    """Test creating new tabs"""
    initial_count = main_window.tab_widget.count()
    main_window.new_tab()
    assert main_window.tab_widget.count() == initial_count + 1
    assert len(main_window.tabs) == initial_count + 1

def test_close_tab(main_window):
    """Test closing tabs"""
    main_window.new_tab()  # Add second tab
    assert main_window.tab_widget.count() == 2
    
    main_window.close_tab(0)
    assert main_window.tab_widget.count() == 1

